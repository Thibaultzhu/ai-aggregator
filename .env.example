# === Server ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080

# === Database ===
DATABASE_URL=postgres://aag:aag_dev_pass@localhost:5432/aggregator?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# === Auth ===
JWT_SECRET=dev-secret-change-in-production-32chars!!
API_KEY_PREFIX=sk-aag-

# === DashScope Provider ===
MOCK_PROVIDER_MODE=true
# DashScope API Keys
# Set DASHSCOPE_API_KEY for universal access, or use CN/INTL specific keys:
DASHSCOPE_API_KEY=
DASHSCOPE_API_KEY_CN=
DASHSCOPE_API_KEY_INTL=
DASHSCOPE_ENDPOINT_CN=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ENDPOINT_INTL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# === Rate Limits ===
DEFAULT_RPM=60
DEFAULT_TPM=100000
DEFAULT_DAILY_QUOTA_USD=100.00

# === Billing ===
NEW_USER_CREDITS_USD=10.00
DEFAULT_MARKUP=1.50

# === Task Engine ===
TASK_WORKER_COUNT=5
